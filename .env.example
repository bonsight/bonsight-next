# Copia este archivo como .env.local y completa los valores
# No commitear .env.local

# ── IA ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Redis / Upstash ─────────────────────────────────────────────
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
KV_URL=

# ── Kai ─────────────────────────────────────────────────────────
# Código de acceso global para el admin de Kai
KAI_ACCESS_CODE=

# Tenants permitidos (comma-separated). Vacío = todos.
# Ejemplo: "bonsight,sesuveca,vivahogar"
ALLOWED_TENANTS=

# ── Google (Aria Intelligence Sources) ──────────────────────────
# JSON completo de la service account — pegar como string en una sola línea
GOOGLE_SERVICE_ACCOUNT_JSON=
